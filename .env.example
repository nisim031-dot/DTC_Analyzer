# העתק קובץ זה ל-.env ומלא את הערכים שלך.
# הבוט (garage_bot_v2.py) טוען אותם אוטומטית בהפעלה.

# טוקן של בוט הטלגרם (מ-@BotFather)
TELEGRAM_TOKEN=

# מזהה הצ'אט/קבוצה שאליו נשלחים הדוחות
CHAT_ID=

# מפתח Google Gemini API
GEMINI_KEY=

# חשבון Gmail שאליו נשלחות סריקות ה-PDF
GMAIL_USER=your_email@gmail.com

# סיסמת אפליקציה של Gmail (App Password — לא הסיסמה הרגילה!)
GMAIL_PASS=
